<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_dashboard_to_needFeed"
            app:destination="@id/needFeedFragment" />
        <action
            android:id="@+id/action_dashboard_to_postNeed"
            app:destination="@id/postNeedFragment" />
        <action
            android:id="@+id/action_dashboard_to_swapManagement"
            app:destination="@id/swapManagementFragment" />
        <action
            android:id="@+id/action_dashboard_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_profile_to_settings"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_profile_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/needFeedFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.NeedFeedFragment"
        android:label="Need Feed"
        tools:layout="@layout/fragment_need_feed">
        <action
            android:id="@+id/action_needFeed_to_offer"
            app:destination="@id/offerFragment" />
    </fragment>

    <fragment
        android:id="@+id/postNeedFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.PostNeedFragment"
        android:label="Post Need"
        tools:layout="@layout/fragment_post_need" />

    <fragment
        android:id="@+id/offerFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.OfferFragment"
        android:label="Offer Skill"
        tools:layout="@layout/fragment_offer">
        <argument
            android:name="postId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/swapManagementFragment"
        android:name="com.example.skillexchangeapp.ui.fragment.HistoryFragment"
        android:label="Swap Management"
        tools:layout="@layout/fragment_history" />

</navigation>
